# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Server Configuration
PORT=3001
NODE_ENV=development
DEV_EMAIL=your-email-here

# Database (SQL Server)
# Local dev — Windows Authentication:
# DATABASE_URL="sqlserver://localhost\\SQLEXPRESS;database=sales_coach_dev;integratedSecurity=true;trustServerCertificate=true"
# Local dev — SQL Auth:
# DATABASE_URL="sqlserver://localhost;database=sales_coach_dev;user=sa;password=yourpassword;trustServerCertificate=true"
# Azure SQL (production):
# DATABASE_URL="sqlserver://yourserver.database.windows.net:1433;database=yourdb;user=youruser;password=yourpass;encrypt=true;trustServerCertificate=false"
DATABASE_URL="sqlserver://localhost:1433;database=sales_coach_dev;integratedSecurity=true;trustServerCertificate=true;encrypt=true"

# Email (Power Automate)
# Create a PA flow: HTTP trigger → Office 365 "Send an email (V2)"
# The flow receives { to, subject, body } and sends — no logic needed on that end.
POWER_AUTOMATE_SEND_URL=https://prod-xx.westus.logic.azure.com/workflows/xxx/triggers/manual/paths/invoke?...

# Cron Schedule (default: 10am Mon–Fri, server local time)
# Standard cron syntax: minute hour day-of-month month day-of-week
DAILY_UPDATE_CRON=0 10 * * 1-5
